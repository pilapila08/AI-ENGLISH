{
  "name": "speakcoach-ai-desktop",
  "version": "0.1.0",
  "description": "A local-first AI English speaking practice desktop client.",
  "author": "SpeakCoach AI",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build:test && node --test dist-tests/tests/scoringService.test.js",
    "build": "tsc -b && vite build && npm run build:electron",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^6.3.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.speakcoach.desktop",
    "productName": "SpeakCoach AI Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "config",
        "to": "config",
        "filter": [
          "scenarios.yaml"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
