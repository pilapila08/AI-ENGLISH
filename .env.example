# OpenAI Compatible API configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Set to true to always use the offline MockLLMProvider.
USE_MOCK_LLM=true

# LLM correction and scoring. Empty values reuse the OPENAI_* configuration.
USE_LLM_ANALYSIS=true
ANALYSIS_API_KEY=
ANALYSIS_BASE_URL=
ANALYSIS_MODEL=

# ASR configuration: mock, whisper, or mimo
ASR_PROVIDER=mock
WHISPER_API_KEY=
WHISPER_BASE_URL=https://api.openai.com/v1
WHISPER_MODEL=whisper-1

# Xiaomi MiMo V2.5 ASR. Leave MIMO_ASR_API_KEY empty to reuse OPENAI_API_KEY.
MIMO_ASR_API_KEY=
MIMO_ASR_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_ASR_MODEL=mimo-v2.5-asr

# TTS configuration: mimo
TTS_PROVIDER=mimo

# Xiaomi MiMo TTS. Leave MIMO_TTS_API_KEY empty to reuse MIMO_API_KEY or OPENAI_API_KEY.
MIMO_TTS_API_KEY=
MIMO_TTS_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_MODEL=mimo-v2.5-tts
MIMO_TTS_VOICE=Chloe
